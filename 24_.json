  "name": "\u041A\u0418\u0407\u041224 | \u0422\u0435\u043B\u0435\u043A\u0430\u043D\u0430\u043B \u041A\u0438\u0457\u0432",
  "youTubeChannelId": "UCcjer2fP4gm72s__h8nqYIQ",
  "episodes": [
    {
      "id": "0ac9bad9-3733-43d1-8ad5-875cf8b375f0",
      "title": "\uD83D\uDCA5 \u041D\u041E\u0412\u0406 \u0416\u0415\u0420\u0422\u0412\u0418 \u0415\u041F\u0428\u0422\u0415\u0419\u041D\u0410 \u0417\u0410\u0413\u041E\u0412\u041E\u0420\u0418\u041B\u0418! \u041A\u0456\u043B\u044C\u043A\u0456\u0441\u0442\u044C \u043F\u043E\u0441\u0442\u0440\u0430\u0436\u0434\u0430\u043B\u0438\u0445 \u0443 \u041F\u0430\u0440\u0438\u0436\u0456 \u0440\u0456\u0437\u043A\u043E \u0437\u0440\u043E\u0441\u043B\u0430",
      "description": "\u0421\u043F\u0440\u0430\u0432\u0430 \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u044C\u043A\u043E\u0433\u043E \u0444\u0456\u043D\u0430\u043D\u0441\u0438\u0441\u0442\u0430-\u043F\u0435\u0434\u043E\u0444\u0456\u043B\u0430 \u0414\u0436\u0435\u0444\u0444\u0440\u0456 \u0415\u043F\u0448\u0442\u0435\u0439\u043D\u0430 \u043D\u0430\u0431\u0438\u0440\u0430\u0454 \u043E\u0431\u0435\u0440\u0442\u0456\u0432 \u0443 \u0404\u0432\u0440\u043E\u043F\u0456! \u041F\u0440\u043E\u043A\u0443\u0440\u043E\u0440\u043A\u0430 \u041F\u0430\u0440\u0438\u0436\u0430 \u041B\u043E\u0440\u0430 \u0411\u0435\u043A\u043A\u043E \u0432 \u0435\u0444\u0456\u0440\u0456 \u0442\u0435\u043B\u0435\u043A\u0430\u043D\u0430\u043B\u0443 RTL \u0437\u0440\u043E\u0431\u0438\u043B\u0430 \u0433\u0443\u0447\u043D\u0443 \u0437\u0430\u044F\u0432\u0443: \u0434\u043E \u043F\u0440\u0430\u0432\u043E\u043E\u0445\u043E\u0440\u043E\u043D\u0446\u0456\u0432 \u0437\u0432\u0435\u0440\u043D\u0443\u043B\u0438\u0441\u044F \u0431\u043B\u0438\u0437\u044C\u043A\u043E \u0434\u0435\u0441\u044F\u0442\u0438 \u043D\u043E\u0432\u0438\u0445 \u0439\u043C\u043E\u0432\u0456\u0440\u043D\u0438\u0445 \u0436\u0435\u0440\u0442\u0432 \u043C\u0456\u043B\u044C\u0439\u043E\u043D\u0435\u0440\u0430. \u0422\u0430\u043A\u0438\u043C \u0447\u0438\u043D\u043E\u043C, \u0437\u0430\u0433\u0430\u043B\u044C\u043D\u0430 \u043A\u0456\u043B\u044C\u043A\u0456\u0441\u0442\u044C \u043F\u043E\u0441\u0442\u0440\u0430\u0436\u0434\u0430\u043B\u0438\u0445, \u044F\u043A\u0456 \u0437\u0430\u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0438 \u0443 \u0424\u0440\u0430\u043D\u0446\u0456\u0457, \u0437\u0440\u043E\u0441\u043B\u0430 \u0432\u0436\u0435 \u0434\u043E \u0434\u0432\u0430\u0434\u0446\u044F\u0442\u0438 \u043E\u0441\u0456\u0431.\n\u0424\u0440\u0430\u043D\u0446\u0443\u0437\u044C\u043A\u0435 \u0440\u043E\u0437\u0441\u043B\u0456\u0434\u0443\u0432\u0430\u043D\u043D\u044F \u0437\u0430 \u0441\u0442\u0430\u0442\u0442\u0435\u044E \u00AB\u0442\u043E\u0440\u0433\u0456\u0432\u043B\u044F \u043B\u044E\u0434\u044C\u043C\u0438\u00BB \u0430\u043A\u0442\u0438\u0432\u0456\u0437\u0443\u0432\u0430\u043B\u043E\u0441\u044F \u043F\u0456\u0441\u043B\u044F \u0442\u043E\u0433\u043E, \u044F\u043A \u0432\u043B\u0430\u0434\u0430 \u0421\u0428\u0410 \u0440\u043E\u0437\u0441\u0435\u043A\u0440\u0435\u0442\u0438\u043B\u0430 \u0442\u0430 \u043E\u043F\u0440\u0438\u043B\u044E\u0434\u043D\u0438\u043B\u0430 \u0442\u0438\u0441\u044F\u0447\u0456 \u0441\u0442\u043E\u0440\u0456\u043D\u043E\u043A \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0456\u0432 \u043F\u0440\u043E \u0437\u043B\u043E\u0447\u0438\u043D\u0438 \u0415\u043F\u0448\u0442\u0435\u0439\u043D\u0430, \u044F\u043A\u0438\u0439 \u0437\u0430\u0433\u0430\u0434\u043A\u043E\u0432\u043E \u043F\u043E\u043C\u0435\u0440 \u0443 \u0432\u0027\u044F\u0437\u043D\u0438\u0446\u0456 \u0443 2019 \u0440\u043E\u0446\u0456. \u042F\u043A\u0443 \u043C\u0435\u0442\u0443 \u043F\u0435\u0440\u0435\u0441\u043B\u0456\u0434\u0443\u0454 \u043F\u0440\u043E\u043A\u0443\u0440\u0430\u0442\u0443\u0440\u0430 \u041F\u0430\u0440\u0438\u0436\u0430, \u044F\u043A\u0438\u0445 \u0432\u0438\u0441\u043E\u043A\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0445 \u043F\u043E\u0441\u0435\u0440\u0435\u0434\u043D\u0438\u043A\u0456\u0432 \u0443 \u0424\u0440\u0430\u043D\u0446\u0456\u0457 \u043D\u0430\u043C\u0430\u0433\u0430\u044E\u0442\u044C\u0441\u044F \u0432\u0438\u0440\u0430\u0445\u0443\u0432\u0430\u0442\u0438 \u0441\u043B\u0456\u0434\u0447\u0456 \u0442\u0430 \u0447\u043E\u043C\u0443 \u0444\u0456\u043D\u0430\u043B \u0446\u0456\u0454\u0457 \u0431\u0440\u0443\u0434\u043D\u043E\u0457 \u0456\u0441\u0442\u043E\u0440\u0456\u0457 \u0449\u0435 \u0434\u0443\u0436\u0435 \u0434\u0430\u043B\u0435\u043A\u043E \u2014 \u0434\u0438\u0432\u0456\u0442\u044C\u0441\u044F \u0443 \u043D\u0430\u0448\u043E\u043C\u0443 \u043C\u0430\u0442\u0435\u0440\u0456\u0430\u043B\u0456.\n\u041F\u0456\u0434\u043F\u0438\u0441\u0443\u0439\u0442\u0435\u0441\u044C \u043D\u0430 \u043D\u0430\u0448 YouTube-\u043A\u0430\u043D\u0430\u043B: https://www.youtube.com/channel/UCcjer2fP4gm72s__h8nqYIQ?sub_confirmation=1 \n\u0413\u043E\u043B\u043E\u0432\u043D\u0456 \u043D\u043E\u0432\u0438\u043D\u0438 \u041A\u0438\u0454\u0432\u0430: https://kyiv24.news/\n\u0427\u0438\u0442\u0430\u0439\u0442\u0435 \u0441\u0432\u0456\u0436\u0456 \u043D\u043E\u0432\u0438\u043D\u0438 \u0432 Telegram: https://t.me/kyivtv \n\u041C\u0438 \u0443 Facebook: https://facebook.com/kyiv24tv\n\u041C\u0438 \u0432 Instagram: https://www.instagram.com/kyiv24_tv\n\u041C\u0438 \u0432 TikTok: https://www.tiktok.com/@kyiv24?_r=1",
