      "id": "b721e5da-c561-4bc8-810b-f56c13695f1b",
      "title": "\u1796\u17B7\u1792\u17B8\u1795\u17D2\u179F\u1796\u17D2\u179C\u1795\u17D2\u179F\u17B6\u1799 \u17A2\u1793\u17BB\u1780\u17D2\u179A\u17B9\u178F\u17D2\u1799 \u179F\u17D2\u178F\u17B8\u1796\u17B8 \u1780\u17B6\u179A\u179A\u17C0\u1794\u1785\u17C6\u1793\u17B7\u1784\u1780\u17B6\u179A\u1794\u17D2\u179A\u1796\u17D2\u179A\u17B9\u178F\u17D2\u178F\u1791\u17C5\u179A\u1794\u179F\u17CB\u1780\u17D2\u179A\u179F\u17BD\u1784\u1792\u1798\u17D2\u1798\u1780\u17B6\u179A\u1793\u17B7\u1784\u179F\u17B6\u179F\u1793\u17B6",
      "description": "(\u179A\u17B6\u1787\u1792\u17B6\u1793\u17B8\u1797\u17D2\u1793\u17C6\u1796\u17C1\u1789) \u1793\u17C5\u1790\u17D2\u1784\u17C3\u1791\u17B8\u17E2\u17E6 \u1781\u17C2\u17A7\u179F\u1797\u17B6 \u1786\u17D2\u1793\u17B6\u17C6\u17E2\u17E0\u17E2\u17E6 \u1793\u17C1\u17C7 \u17AF\u1780\u17A7\u178F\u17D2\u178F\u1798\u1794\u178E\u17D2\u178C\u17B7\u178F \u1785\u17B6\u1799 \u1794\u17BC\u179A\u17B7\u1793 \u1794\u17B6\u1793\u17A2\u1789\u17D2\u1787\u17BE\u1789\u1787\u17B6\u17A2\u1792\u17B7\u1794\u178F\u17B8\u1780\u17D2\u1793\u17BB\u1784\u1796\u17B7\u1792\u17B8\u1794\u17D2\u179A\u1780\u17B6\u179F\u178A\u17B6\u1780\u17CB\u17B1\u17D2\u1799\u17A2\u1793\u17BB\u179C\u178F\u17D2\u178F\u1787\u17B6\u1795\u17D2\u179B\u17BC\u179C\u1780\u17B6\u179A\u1793\u17BC\u179C \u00AB\u17A2\u1793\u17BB\u1780\u17D2\u179A\u17B9\u178F\u17D2\u1799\u179B\u17C1\u1781\u17E6\u17E7 \u17A2\u1793\u1780\u17D2\u179A.\u1794\u1780 \u1785\u17BB\u17C7\u1790\u17D2\u1784\u17C3\u1791\u17B8\u17E2\u17E2 \u1781\u17C2\u1798\u17C1\u179F\u17B6 \u1786\u17D2\u1793\u17B6\u17C6\u17E2\u17E0\u17E2\u17E6 \u179F\u17D2\u178F\u17B8\u1796\u17B8\u1780\u17B6\u179A\u179A\u17C0\u1794\u1785\u17C6 \u1793\u17B7\u1784\u1780\u17B6\u179A\u1794\u17D2\u179A\u1796\u17D2\u179A\u17B9\u178F\u17D2\u178F\u1791\u17C5\u179A\u1794\u179F\u17CB\u1780\u17D2\u179A\u179F\u17BD\u1784\u1792\u1798\u17D2\u1798\u1780\u17B6\u179A\u1793\u17B7\u1784\u179F\u17B6\u179F\u1793\u17B6\u00BB \u178A\u17C2\u179B\u1798\u17B6\u1793\u1780\u17B6\u179A\u1799\u17B6\u1784\u1793\u17B7\u1798\u1793\u17D2\u178F \u1793\u17B7\u1784\u17A2\u1789\u17D2\u1787\u17BE\u1789\u1785\u17BC\u179B\u179A\u17BD\u1798\u1796\u17B8\u179F\u17C6\u178E\u17B6\u1780\u17CB \u179F\u1798\u17D2\u178A\u17C1\u1785\u1796\u17D2\u179A\u17C7\u17A2\u1797\u17B7\u179F\u17B7\u179A\u17B8\u179F\u17BB\u1782\u1793\u17D2\u1792\u17B6\u1798\u17A0\u17B6\u179F\u1784\u17D2\u1783\u179A\u17B6\u1787\u17B6\u1792\u17B7\u1794\u178F\u17B8 \u1780\u17B7\u178F\u17D2\u178F\u17B7\u17A7\u1791\u17D2\u1791\u17C1\u179F\u1794\u178E\u17D2\u178C\u17B7\u178F \u1794\u17BD\u179A \u1782\u17D2\u179A\u17B8 \u179F\u1798\u17D2\u178A\u17C1\u1785\u1796\u17D2\u179A\u17C7\u1798\u17A0\u17B6\u179F\u1784\u17D2\u1783\u179A\u17B6\u1787\u1782\u178E\u17C8\u1792\u1798\u17D2\u1798\u1799\u17BB\u178F\u17D2\u178F\u17B7\u1780\u1793\u17B7\u1780\u17B6\u1799\u1793\u17C3\u1796\u17D2\u179A\u17C7\u179A\u17B6\u1787\u17B6\u178E\u17B6\u1785\u1780\u17D2\u179A\u1780\u1798\u17D2\u1796\u17BB\u1787\u17B6 \u179F\u1798\u17D2\u178F\u17C1\u1785\u1796\u17D2\u179A\u17C7\u1796\u17BB\u1791\u17D2\u1792\u1787\u17D0\u1799\u1798\u17BB\u1793\u17B8\u1794\u178E\u17D2\u178C\u17B7\u178F \u1783\u17B9\u1798 \u179F\u1793 \u179F\u1798\u17D2\u178F\u17C1\u1785\u1796\u17D2\u179A\u17C7\u179F\u1784\u17D2\u1783\u1793\u17B6\u1799\u1780\u179A\u1784\u1791\u17B8\u17E3 \u1796\u17D2\u179A\u17C7\u179A\u17B6\u1787\u178F\u17C6\u178E\u17B6\u1784\u178A\u17CF\u1781\u17D2\u1796\u1784\u17CB\u1781\u17D2\u1796\u179F\u17CB \u179F\u1798\u17D2\u178F\u17C1\u1785\u1796\u17D2\u179A\u17C7\u1798\u17A0\u17B6\u179F\u17BB\u1798\u17C1\u1792\u17B6\u1792\u17B7\u1794\u178F\u17B8 \u1780\u17B7\u178F\u17D2\u178A\u17B7\u1794\u178E\u17D2\u178C\u17B7\u178F \u17A2\u17C6 \u179B\u17B8\u1798\u17A0\u17C1\u1784 \u179F\u1798\u17D2\u178F\u17C1\u1785\u1796\u17D2\u179A\u17C7\u179F\u1784\u17D2\u1783\u1793\u17B6\u1799\u1780 \u1782\u178E\u17C8\u1798\u17A0\u17B6\u1793\u17B7\u1780\u17B6\u1799\u1793\u17C3\u1796\u17D2\u179A\u17C7\u179A\u17B6\u1787\u17B6\u178E\u17B6\u1785\u1780\u17D2\u179A\u1780\u1798\u17D2\u1796\u17BB\u1787\u17B6 \u179F\u1798\u17D2\u178F\u17C1\u1785 \u1796\u17D2\u179A\u17C7\u179A\u17B6\u1787\u17B6\u1782\u178E\u17C8 \u1796\u17D2\u179A\u17C7\u1798\u1793\u17D2\u179A\u17D2\u178F\u17B8\u179F\u1784\u17D2\u1783\u1791\u17B6\u17C6\u1784\u1796\u17B8\u179A\u1782\u178E\u17C8 \u17AF\u1780\u17A7\u178F\u17D2\u178F\u1798 \u179B\u17C4\u1780\u1787\u17C6\u1791\u17B6\u179C \u179A\u178A\u17D2\u178B\u179B\u17C1\u1781\u17B6\u1792\u17B7\u1780\u17B6\u179A \u17AF\u1780\u17A7\u178F\u17D2\u178F\u1798 \u179B\u17C4\u1780\u1787\u17C6\u1791\u17B6\u179C \u17A2\u1793\u17BB\u179A\u178A\u17D2\u178B\u179B\u17C1\u1781\u17B6\u1792\u17B7\u1780\u17B6\u179A \u17AF\u1780\u17A7\u178F\u17D2\u178F\u1798 \u179B\u17C4\u1780\u1787\u17C6\u1791\u17B6\u179C \u178F\u17C6\u178E\u17B6\u1784\u1780\u17D2\u179A\u179F\u17BD\u1784-\u179F\u17D2\u1790\u17B6\u1794\u17D0\u1793\u1796\u17B6\u1780\u17CB\u1796\u17D0\u1793\u17D2\u1792 \u1790\u17D2\u1793\u17B6\u1780\u17CB\u178A\u17B9\u1780\u1793\u17B6\u17C6\u1796\u17B6\u17A0\u17B7\u179A\u179F\u17B6\u179F\u1793\u17B6 \u1794\u17D2\u179A\u1792\u17B6\u1793\u1798\u1793\u17D2\u1791\u17B8\u179A \u179B\u17C4\u1780 \u179B\u17C4\u1780\u179F\u17D2\u179A\u17B8 \u1793\u17B7\u1784\u1798\u1793\u17D2\u178F\u17D2\u179A\u17B8\u179A\u17B6\u1787\u1780\u17B6\u179A\u1787\u17B6\u1785\u17D2\u179A\u17BE\u1793\u179A\u17BC\u1794\u17D4\n\n\u17AF\u1780\u17A7\u178F\u17D2\u178F\u1798\u1794\u178E\u17D2\u178C\u17B7\u178F\u179A\u178A\u17D2\u178B\u1798\u1793\u17D2\u179A\u17D2\u178F\u17B8\u1794\u17B6\u1793\u1782\u17BC\u179F\u1794\u1789\u17D2\u1787\u17B6\u1780\u17CB\u1790\u17B6 \u179B\u17B7\u1781\u17B7\u178F\u1794\u1791\u178A\u17D2\u178B\u17B6\u1793\u1782\u178F\u17B7\u1799\u17BB\u178F\u17D2\u178F\u178A\u17CF\u1798\u17B6\u1793\u179F\u17B6\u179A\u17C8\u179F\u17C6\u1781\u17B6\u1793\u17CB\u1793\u17C1\u17C7 \u1782\u17BA\u1787\u17B6\u179F\u1798\u17B7\u1791\u17D2\u1792\u1795\u179B\u1790\u17D2\u1798\u17B8\u1798\u17BD\u1799\u1791\u17C0\u178F\u178A\u17C2\u179B\u1786\u17D2\u179B\u17BB\u17C7\u1794\u1789\u17D2\u1785\u17B6\u17C6\u1784\u1796\u17B8\u1780\u17B6\u179A\u1794\u17D2\u178F\u17C1\u1787\u17D2\u1789\u17B6\u1785\u17B7\u178F\u17D2\u178F\u1799\u17C9\u17B6\u1784\u1798\u17BB\u178F\u1798\u17B6\u17C6\u179A\u1794\u179F\u17CB\u179A\u17B6\u1787\u179A\u178A\u17D2\u178B\u17B6\u1797\u17B7\u1794\u17B6\u179B\u1780\u1798\u17D2\u1796\u17BB\u1787\u17B6 \u1780\u17D2\u1793\u17BB\u1784\u1780\u17B6\u179A\u1792\u17D2\u179C\u17BE\u1780\u17C6\u178E\u17C2\u1791\u1798\u17D2\u179A\u1784\u17CB\u179F\u17CA\u17B8\u1787\u1798\u17D2\u179A\u17C5\u179B\u17BE\u1794\u17D2\u179A\u1796\u17D0\u1793\u17D2\u1792\u179A\u178A\u17D2\u178B\u1794\u17B6\u179B \u1793\u17B7\u1784\u1780\u17B6\u179A\u1782\u17D2\u179A\u1794\u17CB\u1782\u17D2\u179A\u1784\u179C\u17B7\u179F\u17D0\u1799\u179F\u17B6\u179F\u1793\u17B6 \u1780\u17D2\u1793\u17BB\u1784\u1782\u17C4\u179B\u1794\u17C6\u178E\u1784\u1786\u17D2\u179B\u17BE\u1799\u178F\u1794\u1791\u17C5\u1793\u17B9\u1784\u1780\u17B6\u179A\u179A\u17B8\u1780\u1785\u1798\u17D2\u179A\u17BE\u1793\u1793\u17C3\u179F\u1784\u17D2\u1782\u1798-\u179F\u17C1\u178A\u17D2\u178B\u1780\u17B7\u1785\u17D2\u1785 \u1793\u17B7\u1784\u1780\u17B6\u179A\u179C\u17B7\u179C\u178F\u17D2\u178F\u1793\u17C3\u1794\u1785\u17D2\u1785\u17C1\u1780\u179C\u17B7\u1791\u17D2\u1799\u17B6\u178C\u17B8\u1787\u17B8\u1790\u179B \u178A\u17C4\u1799\u1792\u17B6\u1793\u17B6\u17B1\u17D2\u1799\u1794\u17B6\u1793\u1793\u17BC\u179C\u1782\u17BB\u178E\u1797\u17B6\u1796 \u1782\u178E\u1793\u17C1\u1799\u17D2\u1799\u1797\u17B6\u1796 \u178F\u1798\u17D2\u179B\u17B6\u1797\u17B6\u1796 \u1793\u17B7\u1784\u1794\u179A\u17B7\u1799\u17B6\u1794\u1793\u17D2\u1793\u17D4\n\n\u1791\u17B6\u1780\u17CB\u1791\u1784\u1793\u17B9\u1784\u1780\u17B6\u179A\u1780\u17C2\u179F\u1798\u17D2\u179A\u17BD\u179B\u179A\u1785\u1793\u17B6\u179F\u1798\u17D2\u1796\u17D0\u1793\u17D2\u1792\u179F\u17D2\u1790\u17B6\u1794\u17D0\u1793\u1780\u17D2\u179A\u17C4\u1798\u17A2\u1793\u17BB\u1780\u17D2\u179A\u17B9\u178F\u17D2\u1799\u1790\u17D2\u1798\u17B8\u1793\u17C1\u17C7 \u17AF\u1780\u17A7\u178F\u17D2\u178F\u1798\u1794\u178E\u17D2\u178C\u17B7\u178F\u1794\u17B6\u1793\u1794\u1789\u17D2\u1787\u17B6\u1780\u17CB\u17A2\u17C6\u1796\u17B8\u1780\u17B6\u179A\u1780\u17C2\u179F\u1798\u17D2\u179A\u17BD\u179B\u178A\u17C4\u1799\u1795\u17D2\u17A2\u17C2\u1780\u179B\u17BE\u1780\u17B6\u179A\u179C\u17B7\u1797\u17B6\u1782\u1798\u17BB\u1781\u1784\u17B6\u179A\u179F\u17CA\u17B8\u1787\u1798\u17D2\u179A\u17C5\u178A\u17BE\u1798\u17D2\u1794\u17B8\u1787\u17C0\u179F\u179C\u17B6\u1784\u1797\u17B6\u1796\u178F\u17D2\u179A\u17BD\u178F\u179F\u17CA\u17B8\u1782\u17D2\u1793\u17B6 \u178A\u17C4\u1799\u1780\u17C6\u178E\u178F\u17CB\u1793\u17BC\u179C\u1798\u17BB\u1781\u1784\u17B6\u179A\u179F\u17D2\u1793\u17BC\u179B\u1785\u17C6\u1793\u17BD\u1793\u17E3 \u1793\u17B7\u1784\u1798\u17BB\u1781\u1784\u17B6\u179A\u179A\u1784\u1785\u17C6\u1793\u17BD\u1793\u17E1\u17E7 \u179A\u17BD\u1798\u1787\u17B6\u1798\u17BD\u1799\u1793\u17B9\u1784\u179A\u1785\u1793\u17B6\u179F\u1798\u17D2\u1796\u17D0\u1793\u17D2\u1792\u179F\u17C6\u1781\u17B6\u1793\u17CB\u17D7\u178A\u17BC\u1785\u1787\u17B6\u17D6\n\n-\u17A2\u1782\u17D2\u1782\u179B\u17C1\u1781\u17B6\u1792\u17B7\u1780\u17B6\u179A\u178A\u17D2\u178B\u17B6\u1793 (\u17A2\u178F\u17B8\u178F\u17A2\u1782\u17D2\u1782\u1793\u17B6\u1799\u1780\u178A\u17D2\u178B\u17B6\u1793\u179A\u178A\u17D2\u178B\u1794\u17B6\u179B\u1793\u17B7\u1784\u17A0\u17B7\u179A\u1789\u17D2\u1789\u179C\u178F\u17D2\u1790\u17BB)\u17D6 \u1798\u17B6\u1793\u1780\u17B6\u179A\u1780\u17C2\u179F\u1798\u17D2\u179A\u17BD\u179B\u1788\u17D2\u1798\u17C4\u17C7\u1793\u17B6\u1799\u1780\u178A\u17D2\u178B\u17B6\u1793\u1785\u17C6\u1793\u17BD\u1793\u17E3 \u179A\u1780\u17D2\u179F\u17B6\u1785\u17B6\u179F\u17CB\u17E1 \u1793\u17B7\u1784\u1794\u1784\u17D2\u1780\u17BE\u178F\u1790\u17D2\u1798\u17B8\u17E1(\u1793\u17B6\u1799\u1780\u178A\u17D2\u178B\u17B6\u1793\u1793\u17B8\u178F\u17B7\u1780\u1798\u17D2\u1798 \u1795\u17C2\u1793\u1780\u17B6\u179A \u1793\u17B7\u1784\u179F\u17D2\u1790\u17B7\u178F\u17B7)\u17D4\n\n\u2013 \u17A2\u1782\u17D2\u1782\u1793\u17B6\u1799\u1780\u178A\u17D2\u178B\u17B6\u1793\u1780\u17B7\u1785\u17D2\u1785\u1780\u17B6\u179A\u179F\u17B6\u179F\u1793\u17B6\u17D6 \u179A\u1780\u17D2\u179F\u17B6\u1788\u17D2\u1798\u17C4\u17C7\u178A\u178A\u17C2\u179B \u178F\u17C2\u1798\u17B6\u1793\u1780\u17B6\u179A\u1794\u17D2\u178F\u17BC\u179A\u1788\u17D2\u1798\u17C4\u17C7\u1793\u17B6\u1799\u1780\u178A\u17D2\u178B\u17B6\u1793\u1798\u17BD\u1799\u1785\u17C6\u1793\u17BD\u1793 \u1793\u17B7\u1784\u1780\u17C2\u179F\u1798\u17D2\u179A\u17BD\u179B\u1796\u17BB\u1791\u17D2\u1792\u179F\u17B6\u179F\u1793\u1794\u178E\u17D2\u178C\u17B7\u178F\u17D2\u1799 \u1791\u17C5\u1787\u17B6 \u00AB\u179C\u17B7\u1791\u17D2\u1799\u17B6\u179F\u17D2\u1790\u17B6\u1793\u1796\u17BB\u1791\u17D2\u1792\u179F\u17B6\u179F\u1793\u1794\u178E\u17D2\u178C\u17B7\u178F\u17D2\u1799\u00BB\u17D4\n\n\u2013 \u17A2\u1782\u17D2\u1782\u17B6\u1792\u17B7\u1780\u17B6\u179A\u178A\u17D2\u178B\u17B6\u1793\u1796\u17BB\u1791\u17D2\u1792\u17B7\u1780\u179F\u17B7\u1780\u17D2\u179F\u17B6\u1787\u17B6\u178F\u17B7\u17D6 \u1795\u17D2\u1793\u17C2\u1780\u1785\u17C6\u178E\u17BB\u17C7\u17A2\u1782\u17D2\u1782\u17B6\u1792\u17B7\u1780\u17B6\u179A\u178A\u17D2\u178B\u17B6\u1793\u1796\u17BB\u1791\u17D2\u1792\u17B7\u1780\u179F\u17B7\u1780\u17D2\u179F\u17B6\u1787\u17B6\u178F\u17B7 \u178F\u17D2\u179A\u17BC\u179C\u1794\u17B6\u1793\u1780\u17C2\u179F\u1798\u17D2\u179A\u17BD\u179B \u178A\u17BC\u1785\u1798\u17B6\u1793\u1794\u1784\u17D2\u17A0\u17B6\u1789\u1781\u17B6\u1784\u1780\u17D2\u179A\u17C4\u1798\u17D6\n\n\u17E1.\u1795\u17D2\u1793\u17C2\u1780\u1796\u17BB\u1791\u17D2\u1792\u17B7\u1780\u179F\u17B7\u1780\u17D2\u179F\u17B6 \u1794\u17B6\u1793\u1798\u1780\u1796\u17B8\u1780\u17B6\u179A\u179A\u17BD\u1798\u1794\u1789\u17D2\u1785\u17BC\u179B\u1782\u17D2\u1793\u17B6\u179A\u179C\u17B6\u1784\u1795\u17D2\u1793\u17C2\u1780\u1796\u17BB\u1791\u17D2\u1792\u17B7\u1780\u1794\u178B\u1798\u179F\u17B7\u1780\u17D2\u179F\u17B6\u1793\u17B7\u1784\u1792\u1798\u17D2\u1798\u179C\u17B7\u1793\u17D0\u1799 \u1795\u17D2\u1793\u17C2\u1780\u1796\u17BB\u1791\u17D2\u1792\u17B7\u1780\u1798\u1792\u17D2\u1799\u1798\u179F\u17B7\u1780\u17D2\u179F\u17B6 \u1793\u17B7\u1784\u1795\u17D2\u1793\u17C2\u1780\u1796\u17BB\u1791\u17D2\u1792\u17B7\u1780\u17A7\u178F\u17D2\u178F\u1798\u179F\u17B7\u1780\u17D2\u179F\u17B6\u1793\u17B7\u1784\u1780\u17D2\u179A\u17C4\u1799\u1796\u17BB\u1791\u17D2\u1792\u17B7\u1780\u17A7\u178F\u17D2\u178F\u1798\u179F\u17B7\u1780\u17D2\u179F\u17B6\u17D4\n\n\u17E2.\u1795\u17D2\u1793\u17C2\u1780\u17A2\u1792\u17B7\u1780\u17B6\u179A\u1780\u17B7\u1785\u17D2\u1785\u1796\u17BB\u1791\u17D2\u1792\u17B7\u1780\u179F\u17B7\u1780\u17D2\u179F\u17B6 (\u1796\u17D2\u179A\u17C7\u17A2\u1782\u17D2\u1782\u17B6\u1792\u17B7\u1780\u17B6\u179A\u179F\u17D2\u1793\u17BE\u179F\u17BB\u17C6\u1794\u1784\u17D2\u1780\u17BE\u178F\u1790\u17D2\u1798\u17B8) \u178F\u17D2\u179A\u17BC\u179C\u1794\u17B6\u1793\u179A\u17BD\u1798\u1794\u1789\u17D2\u1785\u17BC\u179B\u1780\u17B6\u179A\u17B7\u1799\u17B6\u179B\u17D0\u1799\u179A\u1794\u17C0\u1794 \u1780\u17B6\u179A\u17B7\u1799\u17B6\u179B\u17D0\u1799\u17A2\u1792\u17B7\u1780\u17B6\u179A\u1780\u17B7\u1785\u17D2\u1785 \u1793\u17C3\u1795\u17D2\u1793\u17C2\u1780\u1796\u17BB\u1791\u17D2\u1792\u17B7\u1780\u1794\u178B\u1798\u179F\u17B7\u1780\u17D2\u179F\u17B6\u1793\u17B7\u1784\u1792\u1798\u17D2\u1798\u179C\u17B7\u1793\u17D0\u1799 \u1780\u17B6\u179A\u17B7\u1799\u17B6\u179B\u17D0\u1799\u17A2\u1792\u17B7\u1780\u17B6\u179A\u1780\u17B7\u1785\u17D2\u1785\u1793\u17C3\u1795\u17D2\u1793\u17C2\u1780\u1796\u17BB\u1791\u17D2\u1792\u17B7\u1780\u1798\u1792\u17D2\u1799\u1798\u179F\u17B7\u1780\u17D2\u179F\u17B6  \u1793\u17B7\u1784\u1780\u17B6\u179A\u17B7\u1799\u17B6\u179B\u17D0\u1799\u17A2\u1792\u17B7\u1780\u17B6\u179A\u1780\u17B7\u1785\u17D2\u1785\u1793\u17C3\u1795\u17D2\u1793\u17C2\u1780\u1796\u17BB\u1791\u17D2\u1792\u17B7\u1780\u17A7\u178F\u17D2\u178F\u1798\u179F\u17B7\u1780\u17D2\u179F\u17B6\u1793\u17B7\u1784\u1780\u17D2\u179A\u17C4\u1799\u1796\u17BB\u1791\u17D2\u1792\u17B7\u1780\u17A7\u178F\u17D2\u178F\u1798\u179F\u17B7\u1780\u17D2\u179F\u17B6\u17D4\n\n\u17E3.\u1795\u17D2\u1793\u17C2\u1780\u1782\u179A\u17BB\u1780\u17C4\u179F\u179B\u17D2\u1799\u1793\u17B7\u1784\u179C\u17B7\u1780\u17D2\u179A\u17B9\u178F\u1780\u17B6\u179A\u1796\u17BB\u1791\u17D2\u1792\u17B7\u1780\u179F\u17B7\u1780\u17D2\u179F\u17B6 \u178F\u17D2\u179A\u17BC\u179C\u1794\u17B6\u1793\u1795\u17D2\u1791\u17C1\u179A\u1796\u17B8\u1796\u17BB\u1791\u17D2\u1792\u17B7\u1780\u179F\u17B6\u1780\u179B\u179C\u17B7\u1791\u17D2\u1799\u17B6\u179B\u17D0\u1799\u1796\u17D2\u179A\u17C7\u179F\u17B8\u17A0\u1793\u17BB\u179A\u17B6\u1787\u17A0\u17BE\u1799\u1794\u17D2\u178F\u17BC\u179A\u1788\u17D2\u1798\u17C4\u17C7 \u1796\u17B8\u1798\u1787\u17D2\u1788\u1798\u178E\u17D2\u178C\u179B\u1782\u179A\u17BB\u1780\u17C4\u179F\u179B\u17D2\u1799\u179A\u1794\u179F\u17CB\u1796\u17BB\u1791\u17D2\u1792\u17B7\u1780\u179F\u17B6\u1780\u179B\u179C\u17B7\u1791\u17D2\u1799\u17B6\u179B\u17D0\u1799\u1796\u17D2\u179A\u17C7\u179F\u17B8\u17A0\u1793\u17BB\u179A\u17B6\u1787 \u1791\u17C5\u1787\u17B6 \u1795\u17D2\u1793\u17C2\u1780\u1782\u179A\u17BB\u1780\u17C4\u179F\u179B\u17D2\u1799\u1793\u17B7\u1784\u179C\u17B7\u1780\u17D2\u179A\u17B9\u178F\u1780\u17B6\u179A\u1796\u17BB\u1791\u17D2\u1792\u17B7\u1780\u179F\u17B7\u1780\u17D2\u179F\u17B6 \u17D4\n\n\u17E4.\u1795\u17D2\u1793\u17C2\u1780\u179A\u178A\u17D2\u178B\u1794\u17B6\u179B\u1793\u17B7\u1784\u1782\u178E\u1793\u17C1\u1799\u17D2\u1799  \u179A\u1780\u17D2\u179F\u17B6\u1791\u17BB\u1780\u178A\u178A\u17C2\u179B\u17D4\n\n-\u1793\u17B6\u1799\u1780\u178A\u17D2\u178B\u17B6\u1793\u179F\u179C\u1793\u1780\u1798\u17D2\u1798\u1795\u17D2\u1791\u17C3\u1780\u17D2\u1793\u17BB\u1784\u17D6 \u178F\u17D2\u179A\u17BC\u179C\u1794\u17B6\u1793\u179A\u1780\u17D2\u179F\u17B6\u1791\u17BB\u1780\u178A\u178A\u17C2\u179B \u178A\u17C4\u1799\u179B\u17BB\u1794\u1785\u17C4\u179B\u17A2\u1792\u17B7\u1780\u17B6\u179A\u178A\u17D2\u178B\u17B6\u1793\u17D4\n\n\u2013 \u17A2\u1784\u17D2\u1782\u1797\u17B6\u1796\u1790\u17D2\u1793\u17B6\u1780\u17CB\u1780\u17D2\u179A\u17C4\u1798\u1787\u17B6\u178F\u17B7\u17D6 \u1794\u1793\u17D2\u178F\u179A\u1780\u17D2\u179F\u17B6\u1798\u1793\u17D2\u1791\u17B8\u179A\u1792\u1798\u17D2\u1798\u1780\u17B6\u179A \u1793\u17B7\u1784\u179F\u17B6\u179F\u1793\u17B6\u179A\u17B6\u1787\u1792\u17B6\u1793\u17B8-\u1781\u17C1\u178F\u17D2\u178F\u17D4\n\n\u178A\u17BE\u1798\u17D2\u1794\u17B8\u17B1\u17D2\u1799\u1780\u17B6\u179A\u17A2\u1793\u17BB\u179C\u178F\u17D2\u178F\u17A2\u1793\u17BB\u1780\u17D2\u179A\u17B9\u178F\u17D2\u1799\u1790\u17D2\u1798\u17B8\u1793\u17C1\u17C7\u1791\u1791\u17BD\u179B\u1794\u17B6\u1793\u179B\u1791\u17D2\u1792\u1795\u179B\u1795\u17D2\u179B\u17C2\u1795\u17D2\u1780\u17B6 \u1793\u17B7\u1784\u1798\u17B6\u1793\u1794\u17D2\u179A\u179F\u17B7\u1791\u17D2\u1792\u1797\u17B6\u1796\u1781\u17D2\u1796\u179F\u17CB \u17AF\u1780\u17A7\u178F\u17D2\u178F\u1798\u1794\u178E\u17D2\u178C\u17B7\u178F \u1785\u17B6\u1799 \u1794\u17BC\u179A\u17B7\u1793 \u1780\u17CF\u1794\u17B6\u1793\u178A\u17B6\u1780\u17CB\u1785\u17C1\u1789\u1793\u17BC\u179C\u1791\u17B7\u179F\u178A\u17C5\u1780\u17B6\u179A\u1784\u17B6\u179A\u1782\u1793\u17D2\u179B\u17B9\u17C7\u1785\u17C6\u1793\u17BD\u1793 \u17E8\u1785\u17C6\u178E\u17BB\u1785 \u178A\u179B\u17CB\u1790\u17D2\u1793\u17B6\u1780\u17CB\u178A\u17B9\u1780\u1793\u17B6\u17C6 \u1793\u17B7\u1784\u1798\u1793\u17D2\u178F\u17D2\u179A\u17B8\u179A\u17B6\u1787\u1780\u17B6\u179A\u1793\u17C3\u1780\u17D2\u179A\u179F\u17BD\u1784\u1792\u1798\u17D2\u1798\u1780\u17B6\u179A\u1793\u17B7\u1784\u179F\u17B6\u179F\u1793\u17B6\u1791\u17B6\u17C6\u1784\u17A2\u179F\u17CB \u178A\u17BC\u1785\u1781\u17B6\u1784\u1780\u17D2\u179A\u17C4\u1798\u17D6\n\n\u17E1. \u1780\u17B6\u179A\u1792\u17D2\u179C\u17BE\u1791\u17C6\u1793\u17BE\u1794\u1780\u1798\u17D2\u1798\u179F\u17D2\u1790\u17B6\u1794\u17D0\u1793 \u178A\u17BE\u1798\u17D2\u1794\u17B8\u1786\u17D2\u179B\u17BE\u1799\u178F\u1794\u1794\u179A\u17B7\u1794\u1791\u179F\u1780\u179B\u1797\u17B6\u179C\u17BC\u1794\u1793\u17B8\u1799\u1780\u1798\u17D2\u1798 \u1787\u17B6\u1798\u17BD\u1799\u1793\u17B9\u1784\u1780\u17B6\u179A\u1794\u17C2\u1784\u1785\u17C2\u1780\u178F\u17BD\u1793\u17B6\u1791\u17B8\u1785\u17D2\u1794\u17B6\u179F\u17CB\u179B\u17B6\u179F\u17CB\u17D4\n\n\u17E2. \u1780\u17B6\u179A\u1796\u1784\u17D2\u179A\u17B9\u1784\u179F\u1798\u178F\u17D2\u1790\u1797\u17B6\u1796\u1798\u1793\u17D2\u178F\u17D2\u179A\u17B8\u179A\u17B6\u1787\u1780\u17B6\u179A \u178F\u17B6\u1798\u179A\u1799\u17C8\u1780\u17B6\u179A\u1794\u178E\u17D2\u178F\u17BB\u17C7\u1794\u178E\u17D2\u178F\u17B6\u179B\u1794\u1793\u17D2\u178F\u17D4\n\n\u17E3. \u1780\u17C6\u178E\u17C2\u1791\u1798\u17D2\u179A\u1784\u17CB\u179A\u178A\u17D2\u178B\u1794\u17B6\u179B \u1793\u17B7\u1784\u17A2\u1797\u17B7\u1780\u17D2\u179A\u1798\u1780\u17B6\u179A\u1784\u17B6\u179A \u178A\u17C4\u1799\u178F\u17D2\u179A\u17BC\u179C\u1792\u17D2\u179C\u17BE\u1791\u17C6\u1793\u17BE\u1794\u1780\u1798\u17D2\u1798\u1794\u17D2\u179A\u1796\u17D0\u1793\u17D2\u1792\u1791\u17B7\u1793\u17D2\u1793\u1793\u17D0\u1799\u1798\u1793\u17D2\u178F\u17D2\u179A\u17B8 (\u1787\u17C6\u179A\u17BF\u1793 \u1793\u17B7\u1784\u1787\u17B8\u179C\u1798\u17B6\u178F\u17D2\u179A) \u178A\u17BE\u1798\u17D2\u1794\u17B8\u178F\u1798\u17D2\u179B\u17B6\u1797\u17B6\u1796 \u1793\u17B7\u1784\u1797\u17B6\u1796\u1787\u17B6\u1798\u17D2\u1785\u17B6\u179F\u17CB\u1780\u17B6\u179A\u17D4\n\n\u17E4. \u1780\u17B6\u179A\u1796\u17B7\u1793\u17B7\u178F\u17D2\u1799\u1798\u17BB\u1781\u1784\u17B6\u179A\u17B1\u17D2\u1799\u1794\u17B6\u1793\u1785\u17D2\u1794\u17B6\u179F\u17CB\u179B\u17B6\u179F\u17CB \u178A\u17BE\u1798\u17D2\u1794\u17B8\u1785\u17C0\u179F\u179C\u17B6\u1784\u1780\u17B6\u179A\u1787\u17B6\u1793\u17CB\u178F\u17BD\u1793\u17B6\u1791\u17B8\u1782\u17D2\u1793\u17B6\u17D4\n\n\u17E5. \u1780\u17B6\u179A\u1794\u1784\u17D2\u1780\u17BE\u1793\u1780\u17B6\u179A\u179F\u1798\u17D2\u179A\u1794\u179F\u1798\u17D2\u179A\u17BD\u179B \u1793\u17B7\u1784\u1780\u17B7\u1785\u17D2\u1785\u179F\u17A0\u1780\u17B6\u179A\u17A2\u1793\u17D2\u178F\u179A\u1793\u17B6\u1799\u1780\u178A\u17D2\u178B\u17B6\u1793\u17B1\u17D2\u1799\u1794\u17B6\u1793\u179A\u179B\u17BC\u1793 \u1793\u17B7\u1784\u1791\u17B6\u1793\u17CB\u1796\u17C1\u179B\u179C\u17C1\u179B\u17B6\u17D4\n\n\u17E6. \u1780\u17B6\u179A\u179A\u17C0\u1794\u1785\u17C6\u179A\u1785\u1793\u17B6\u179F\u1798\u17D2\u1796\u17D0\u1793\u17D2\u1792\u1790\u17D2\u1798\u17B8 \u178F\u17D2\u179A\u17BC\u179C\u178A\u17BE\u179A\u1791\u1793\u17D2\u1791\u17B9\u1798\u1782\u17D2\u1793\u17B6\u1793\u17B9\u1784\u1780\u17B6\u179A\u1780\u17C2\u1791\u1798\u17D2\u179A\u1784\u17CB\u1780\u17B6\u179A\u1782\u17D2\u179A\u1794\u17CB\u1782\u17D2\u179A\u1784\u1798\u1793\u17D2\u178F\u17D2\u179A\u17B8 \u178A\u17C4\u1799\u178A\u17B6\u1780\u17CB\u1796\u1784\u17D2\u179A\u17B6\u1799\u1798\u1793\u17D2\u178F\u17D2\u179A\u17B8\u17B1\u17D2\u1799\u1785\u17C6\u1787\u17C6\u1793\u17B6\u1789\u17D4\n\n\u17E7. \u1794\u1793\u17D2\u178F\u179A\u17C0\u1794\u1785\u17C6\u1794\u17D2\u179A\u1796\u17D0\u1793\u17D2\u1792\u179B\u17BE\u1780\u1791\u17B9\u1780\u1785\u17B7\u178F\u17D2\u178F \u1793\u17B7\u1784\u1780\u17B6\u179A\u179C\u17B6\u1799\u178F\u1798\u17D2\u179B\u17C3\u178A\u17C4\u1799\u1795\u17D2\u17A2\u17C2\u1780\u179B\u17BE\u179F\u1798\u17B7\u1791\u17D2\u1792\u1780\u1798\u17D2\u1798\u1780\u17B6\u179A\u1784\u17B6\u179A\u1796\u17B7\u178F\u1794\u17D2\u179A\u17B6\u1780\u178A \u1794\u17D2\u179A\u1780\u1794\u178A\u17C4\u1799\u1799\u17BB\u178F\u17D2\u178F\u17B7\u1792\u1798\u17CC \u1793\u17B7\u1784\u178F\u1798\u17D2\u179B\u17B6\u1797\u17B6\u1796\u17D4\n\n\u17E8. \u1780\u17B6\u179A\u1796\u1784\u17D2\u179A\u17B9\u1784\u1795\u179B\u1794\u17D2\u179A\u1799\u17C4\u1787\u1793\u17CD\u179A\u17BD\u1798 \u178A\u17C4\u1799\u178F\u17D2\u179A\u17BC\u179C\u1794\u17D2\u179A\u1780\u17B6\u1793\u17CB\u1781\u17D2\u1787\u17B6\u1794\u17CB\u1793\u17BC\u179C\u179F\u17D2\u1798\u17B6\u179A\u178F\u17B8\u179F\u17B6\u1798\u1782\u17D2\u1782\u17B8\u1797\u17B6\u1796 \u1782\u17B7\u178F\u1782\u17BC\u179A\u1796\u17B8\u1796\u17B6\u1780\u17D2\u1799\u1790\u17B6 \u00AB\u1799\u17BE\u1784\u00BB \u1787\u17B6\u1787\u17B6\u1784\u1796\u17B6\u1780\u17D2\u1799\u1790\u17B6 \u00AB\u1781\u17D2\u1789\u17BB\u17C6\u00BB \u178A\u17C4\u1799\u178F\u1798\u17D2\u1780\u179B\u17CB\u17A7\u178F\u17D2\u178F\u1798\u1794\u17D2\u179A\u1799\u17C4\u1787\u1793\u17CD\u179A\u17BD\u1798 \u1793\u17B7\u1784\u179F\u1798\u17B7\u1791\u17D2\u1792\u1795\u179B\u179A\u1794\u179F\u17CB\u1780\u17D2\u179A\u179F\u17BD\u1784\u1787\u17B6\u1792\u17C6\u17D4\n\n\u1798\u17BB\u1793\u1793\u17B9\u1784\u1794\u1789\u17D2\u1785\u1794\u17CB\u17AF\u1780\u17A7\u178F\u17D2\u178F\u1798\u1794\u178E\u17D2\u178C\u17B7\u178F\u179A\u178A\u17D2\u178B\u1798\u1793\u17D2\u179A\u17D2\u178F\u17B8 \u1794\u17B6\u1793\u179F\u1798\u17D2\u178F\u17C2\u1784\u1793\u17BC\u179C\u1780\u17D2\u178F\u17B8\u179F\u1784\u17D2\u1783\u17B9\u1798\u1799\u17C9\u17B6\u1784\u1798\u17BB\u178F\u1798\u17B6\u17C6\u1790\u17B6 \u17A2\u1793\u17BB\u1780\u17D2\u179A\u17B9\u178F\u17D2\u1799\u1790\u17D2\u1798\u17B8\u1793\u17C1\u17C7\u1793\u17B9\u1784\u1780\u17D2\u179B\u17B6\u1799\u1787\u17B6\u1780\u17D2\u1794\u17B6\u179B\u1798\u17C9\u17B6\u179F\u17CA\u17B8\u1793 \u1793\u17B7\u1784\u1787\u17B6\u1780\u17D2\u179A\u1794\u1781\u178E\u17D2\u178C\u1782\u178F\u17B7\u1799\u17BB\u178F\u17D2\u178F\u178A\u17CF\u179A\u17B9\u1784\u1798\u17B6\u17C6 \u1796\u17D2\u179A\u1798\u1791\u17B6\u17C6\u1784\u1794\u17B6\u1793\u17A2\u17C6\u1796\u17B6\u179C\u1793\u17B6\u179C\u178A\u179B\u17CB \u179F\u1798\u17D2\u178F\u17C1\u1785 \u1796\u17D2\u179A\u17C7\u1790\u17C1\u179A\u17B6\u1793\u17BB\u178F\u17D2\u1790\u17C1\u179A\u17C8\u1782\u17D2\u179A\u1794\u17CB\u1796\u17D2\u179A\u17C7\u17A2\u1784\u17D2\u1782 \u1793\u17B7\u1784\u1798\u1793\u17D2\u178F\u17D2\u179A\u17B8\u179A\u17B6\u1787\u1780\u17B6\u179A\u1791\u17B6\u17C6\u1784\u17A2\u179F\u17CB \u17B1\u17D2\u1799\u1794\u1793\u17D2\u178F\u1785\u17BC\u179B\u179A\u17BD\u1798\u179B\u17C7\u1794\u1784\u17CB\u1780\u1798\u17D2\u179B\u17B6\u17C6\u1784\u1780\u17B6\u1799\u1785\u17B7\u178F\u17D2\u178F \u1794\u17D2\u179A\u1780\u1794\u178A\u17C4\u1799\u1798\u1793\u179F\u17B7\u1780\u17B6\u179A \u1793\u17B7\u1784\u179F\u17D2\u1798\u17B6\u179A\u178F\u17B8\u1791\u1791\u17BD\u179B\u1781\u17BB\u179F\u178F\u17D2\u179A\u17BC\u179C\u1781\u17D2\u1796\u179F\u17CB \u178A\u17BE\u1798\u17D2\u1794\u17B8\u179A\u17BB\u1789\u1785\u17D2\u179A\u17B6\u1793\u179C\u17B7\u179F\u17D0\u1799\u1792\u1798\u17D2\u1798\u1780\u17B6\u179A \u1793\u17B7\u1784\u179F\u17B6\u179F\u1793\u17B6\u1793\u17C5\u1780\u1798\u17D2\u1796\u17BB\u1787\u17B6 \u17B1\u17D2\u1799\u1780\u17B6\u1793\u17CB\u178F\u17C2\u179A\u17B8\u1780\u1785\u1798\u17D2\u179A\u17BE\u1793\u179A\u17BB\u1784\u17